# XAU MT4 Bridge production config
BRIDGE_API_TOKEN=replace-with-very-strong-random-token
SIGNAL_STORE=latest_signal.json
JOURNAL_STORE=journal.log
NEWS_CACHE_FILE=news_cache.json
NEWS_CALENDAR_URL=https://nfs.faireconomy.media/ff_calendar_thisweek.json
NEWS_REFRESH_SEC=1800
DEFAULT_NEWS_BLOCK_MINUTES=45
AI4TRADE_TOKEN=replace-with-ai4trade-agent-token
AI4TRADE_AGENT_ID=3065
AI4TRADE_REQUIRE_AGENT_MATCH=true
AI4TRADE_ALLOWED_SYMBOLS=XAUUSD,GBPUSD,EURUSD
AI4TRADE_FEED_URL=https://ai4trade.ai/api/signals/feed
AI4TRADE_POLL_SEC=30
AI4TRADE_MIN_CONFIDENCE=0.5
AI4TRADE_RAW_STORE=ai4trade_last_raw.json
AI4TRADE_DRY_RUN=true
AI4TRADE_DRY_RUN_LOG=ai4trade_dry_run.log
AI4TRADE_PUBLISH_URL=https://ai4trade.ai/api/signals/realtime
AI4TRADE_PUBLISH_MARKET=forex
AI4TRADE_PUBLISH_QUANTITY=0.01
GENERATOR_SYMBOL=XAUUSD
GENERATOR_TIMEFRAME=M15
GENERATOR_CONFIDENCE=0.6
MARKET_RECEIVER_PORT=80
MARKET_SNAPSHOT_STORE=latest_market_snapshot.json
AI_SIGNAL_STATE_FILE=ai_signal_state.json
AI_SIGNAL_PROCESSING_INTERVAL_SEC=0.1
ACTIVE_SIGNAL_TTL_SEC=120
REVERSAL_ON_OPEN_POSITION=false
POST_CLOSE_COOLDOWN_SEC=30
LOSS_COOLDOWN_SEC=180
MAX_CONSECUTIVE_LOSSES_PER_SIDE=2
XAU_ENTRY_ZONE_MIN=0.5
XAU_ENTRY_ZONE_MAX=1.5
XAU_ENTRY_ZONE_RANGE_MULT=0.35
FOREX_ENTRY_ZONE_MIN=0.0005
FOREX_ENTRY_ZONE_MAX=0.0015
FOREX_ENTRY_ZONE_RANGE_MULT=0.25
AI_SIGNAL_PUBLISH_ENABLED=true
AI_SIGNAL_IGNORE_PUBLISH_ERRORS=true
AI_GENERATED_SIGNAL_STORE=generated_ai_signal.json
XAU_MAX_SPREAD_POINTS=120
FOREX_MAX_SPREAD_POINTS=35
GEMINI_DECIDER_ENABLED=true
GEMINI_DECIDER_MODEL=gemini-2.5-flash
GEMINI_MIN_CONFIDENCE=0.55
GEMINI_DEBUG=true
SESSION_FILTER_ENABLED=true
SESSION_START_HOUR_UTC=6
SESSION_END_HOUR_UTC=21
XAU_MIN_CANDLE_RANGE=0.8
XAU_MAX_CANDLE_RANGE=8.0
FOREX_MIN_CANDLE_RANGE=0.0005
FOREX_MAX_CANDLE_RANGE=0.0080
LATE_ENTRY_RANGE_FACTOR=0.75
EXHAUSTION_BODY_RATIO=0.80
GEMINI_OVERRIDE_CONFIDENCE=0.72
# Operator endpoints: /strategy/status and /risk/status expose effective runtime risk config.
